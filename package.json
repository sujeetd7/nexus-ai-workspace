{
  "name": "nexus-ai-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise AI Platform – ChatGPT + Copilot + Notion AI + Slack AI + GitHub Copilot",
  "workspaces": [
    "backend/services/*",
    "shared"
  ],
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint-fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky install",
    "db:migrate": "turbo run db:migrate --filter=@nexus/database",
    "db:studio": "turbo run db:studio --filter=@nexus/database"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.1",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
