<file path="src/repositories/session/session.repository.ts">
import { randomUUID } from "crypto";

import { Session } from "../../types/interfaces/session.interface";

import { ISessionRepository } from "../../types/interfaces/session.repository.interface";

export class SessionRepository implements ISessionRepository {
  private sessions = new Map<string, Session>();

  async create(session: Omit<Session, "id">): Promise<Session> {
    const newSession = {
      id: randomUUID(),
      ...session,
    };

    this.sessions.set(newSession.id, newSession);

    return newSession;
  }

  async findByTokenHash(hash: string): Promise<Session | null> {
    const now = new Date();

    for (const session of this.sessions.values()) {
      if (
        session.refreshTokenHash === hash &&
        !session.revoked &&
        session.expiresAt > now
      ) {
        return session;
      }
    }

    return null;
  }

  async findAnyByTokenHash(hash: string): Promise<Session | null> {
    for (const session of this.sessions.values()) {
      if (session.refreshTokenHash === hash) {
        return session;
      }
    }

    return null;
  }

  async revoke(id: string): Promise<void> {
    const session = this.sessions.get(id);

    if (session) {
      session.revoked = true;
    }
  }

  async revokeUserSessions(userId: string): Promise<void> {
    for (const session of this.sessions.values()) {
      if (session.userId === userId) {
        session.revoked = true;
      }
    }
  }

  async findByUserId(userId: string): Promise<Session[]> {
    return [...this.sessions.values()].filter(
      (s) => s.userId === userId && !s.revoked,
    );
  }

  async revokeUserSession(userId: string, sessionId: string): Promise<void> {
    const session = this.sessions.get(sessionId);

    if (session && session.userId === userId) {
      session.revoked = true;
    }
  }

  async revokeAsRotated(sessionId: string, replacement: string): Promise<void> {
    const session = this.sessions.get(sessionId);

    if (session) {
      session.revoked = true;

      session.revokedReason = "ROTATED";

      session.replacedByToken = replacement;
    }
  }

  async touch(sessionId: string, usedAt: Date): Promise<void> {
    const session = this.sessions.get(sessionId);

    if (session) {
      session.lastUsedAt = usedAt;
    }
  }
}

export const sessionRepository = new SessionRepository();
</file>

